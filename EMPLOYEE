#include <iostream>
#include <cstring>
using namespace std;

class Employee
{
    char *name;
    float salary;

public:
    Employee(char n[], float s)
    {
        name = new char[strlen(n) + 1];
        strcpy(name, n);
        salary = s;
    }

    void getData(char n[], float s)
    {
        delete[] name;
        name = new char[strlen(n) + 1];
        strcpy(name, n);
        salary = s;
    }

    void display()
    {
        cout << "Name: " << name << endl;
        cout << "Salary: " << salary << endl;
    }

    ~Employee()
    {
        delete[] name;
    }
};

int main()
{
    Employee e1((char *)"Jessica", 50000);

    e1.display();

    return 0;
}
