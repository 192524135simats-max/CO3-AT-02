#include <iostream>
#include <cstring>
using namespace std;

class Student
{
    char *name;
    int marks;

public:
    Student(char n[], int m)
    {
        name = new char[strlen(n) + 1];
        strcpy(name, n);
        marks = m;
    }

    Student(const Student &s)
    {
        name = new char[strlen(s.name) + 1];
        strcpy(name, s.name);
        marks = s.marks;
    }

    void getData(char n[], int m)
    {
        delete[] name;
        name = new char[strlen(n) + 1];
        strcpy(name, n);
        marks = m;
    }

    void display()
    {
        cout << "Name: " << name << endl;
        cout << "Marks: " << marks << endl;
    }

    ~Student()
    {
        delete[] name;
    }
};

int main()
{
    Student s1((char *)"Jessica", 85);

    Student s2 = s1;

    s2.getData((char *)"John", 95);

    cout << "Original Object:" << endl;
    s1.display();

    cout << endl;

    cout << "Copied Object:" << endl;
    s2.display();

    return 0;
}
